# Exemplu de configurare. Copiază în `secrets.toml` și completează valorile.

# Adresa pe care se trimite codul de administrare.
admin_email = "adresa-ta@gmail.com"

# Setări SMTP (gratuit cu Gmail + parolă de aplicație: https://myaccount.google.com/apppasswords)
smtp_host = "smtp.gmail.com"
smtp_port = 587
smtp_user = "adresa-de-trimitere@gmail.com"
smtp_password = "parola-de-aplicatie-16-caractere"

# Mod testare locală: dacă emailul nu e configurat, codul apare pe ecran.
otp_debug = false
